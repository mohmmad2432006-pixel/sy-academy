# ==============================
# Sy-Academy - متغيرات البيئة
# انسخ هذا الملف وسمّه .env.local
# ثم أضف قيمك الحقيقية
# ==============================

# === MongoDB ===
# احصل عليه من: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/sy-academy?retryWrites=true&w=majority

# === Firebase Auth ===
# احصل عليها من: https://console.firebase.google.com
# Project Settings > General > Your Apps > Web App
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=sy-academy.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sy-academy
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=sy-academy.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdefabcdefabcdef

# === Next.js ===
NEXTAUTH_SECRET=your-super-secret-key-here-change-this
NEXTAUTH_URL=http://localhost:3000

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Sy-Academy
