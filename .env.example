# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/sy-academy

# Firebase Client (Public)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=sy-academy.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sy-academy
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=sy-academy.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin (Secret - Server Only)
FIREBASE_PROJECT_ID=sy-academy
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@sy-academy.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
